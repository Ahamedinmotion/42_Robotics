generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// Enums
// =======================

enum Role {
  STUDENT
  SECRETARY
  PROJECT_MANAGER
  SOCIAL_MEDIA_MANAGER
  VP
  PRESIDENT
}

enum Status {
  WAITLIST
  ACTIVE
  BLACKHOLED
  ALUMNI
}

enum Rank {
  E
  D
  C
  B
  A
  S
}

enum Theme {
  FORGE
  FIELD
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum TeamStatus {
  FORMING
  ACTIVE
  EVALUATING
  COMPLETED
  BLACKHOLED
}

enum EvaluationSlotStatus {
  OPEN
  FILLED
  CLOSED
}

enum EvaluationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum EvaluationResult {
  PASS
  FAIL
}

enum FeedbackRole {
  TEAM
  EVALUATOR
  PEER
}

enum CheckoutStatus {
  OUT
  RETURNED
  OVERDUE
  FLAGGED
}

enum MachineType {
  PRINTER_FDM
  PRINTER_RESIN
  CNC
}

enum ReqStatus {
  PENDING
  APPROVED
  REJECTED
  SCHEDULED
  COMPLETED
}

enum DamageStatus {
  REPORTED
  UNDER_REVIEW
  RESOLVED
}

enum MaterialReqStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
  CONVERTED
}

enum NotificationType {
  EVAL_SLOT_AVAILABLE
  BLACKHOLE_WARNING
  PRINT_APPROVED
  REPORT_DUE
  WORKSHOP_ANNOUNCED
  ACHIEVEMENT_UNLOCKED
  FEEDBACK_RECEIVED
  MATERIAL_REQUEST_UPDATE
  DAMAGE_REPORT_UPDATE
  GENERAL
}

enum ConflictStatus {
  OPEN
  REVIEWED
  RESOLVED
}

enum RsvpStatus {
  GOING
  NOT_GOING
}

enum AuthMethod {
  FINGERPRINT
  QR_CODE
}

// =======================
// Models
// =======================

model User {
  id                   String            @id @default(cuid())
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  fortyTwoId           String?           @unique @map("forty_two_id")
  login                String            @unique @default(cuid())
  email                String?           @unique
  emailVerified        DateTime?         @map("email_verified")
  name                 String            @default("")
  image                String?           @map("image")
  role                 Role              @default(STUDENT)
  status               Status            @default(WAITLIST)
  currentRank          Rank              @default(E) @map("current_rank")
  labAccessEnabled     Boolean           @default(false) @map("lab_access_enabled")
  githubHandle         String?           @map("github_handle")
  activeTheme          Theme             @default(FORGE) @map("active_theme")
  joinedAt             DateTime          @default(now()) @map("joined_at")

  // Relations
  teams                TeamMember[]
  evaluationsGiven     Evaluation[]      @relation("Evaluator")
  notifications        Notification[]
  achievements         UserAchievement[]
  checkouts            Checkout[]
  fabricationRequests  FabricationRequest[] @relation("Requestor")
  fabricationReviewed  FabricationRequest[] @relation("FabricationReviewer")
  damageReports        DamageReport[]    @relation("Reporter")
  damageResolved       DamageReport[]    @relation("DamageResolver")
  weeklyReports        WeeklyReport[]
  conflictFlagsRaised  ConflictFlag[]    @relation("ConflictRaiser")
  conflictFlagsReviewed ConflictFlag[]   @relation("ConflictReviewer")
  alumniEvaluatorOptIn AlumniEvaluator?
  projectsCreated      Project[]         @relation("ProjectCreator")
  teamsLed             Team[]            @relation("TeamLeader")
  materialRequests     MaterialRequest[] @relation("MaterialRequestor")
  materialReviewed     MaterialRequest[] @relation("MaterialReviewer")
  projectProposals     ProjectProposal[] @relation("ProposalCreator")
  proposalsReviewed    ProjectProposal[] @relation("ProposalReviewer")
  workshopsHosted      Workshop[]        @relation("WorkshopHost")
  workshopRsvps        WorkshopRSVP[]
  labAccessLogs        LabAccessLog[]
  feedbackReceived     EvaluationFeedback[] @relation("FeedbackReceiver")
  skillProgress        UserSkillProgress[]
  accounts             Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Project {
  id                 String            @id @default(cuid())
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  title              String
  description        String            @db.Text
  rank               Rank
  status             ProjectStatus     @default(DRAFT)
  teamSizeMin        Int               @map("team_size_min")
  teamSizeMax        Int               @map("team_size_max")
  blackholeDays      Int               @map("blackhole_days")
  skillTags          String[]          @map("skill_tags")
  isUnique           Boolean           @default(false) @map("is_unique")
  subjectSheetUrl    String?           @map("subject_sheet_url")
  evaluationSheetUrl String?           @map("evaluation_sheet_url")

  // Relations
  createdById        String            @map("created_by_id")
  createdBy          User              @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  teams              Team[]
  evaluations        Evaluation[]
  proposalsConverted ProjectProposal[] @relation("ConvertedProject")

  @@map("projects")
  @@index([createdById])
}

model UserSkillProgress {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  skillTag          String   @map("skill_tag")
  projectsCompleted Int      @default(0) @map("projects_completed")

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillTag])
  @@map("user_skill_progress")
  @@index([userId])
}

model Team {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  projectId          String             @map("project_id")
  leaderId           String             @map("leader_id")
  status             TeamStatus         @default(FORMING)
  activatedAt        DateTime?          @map("activated_at")
  blackholeDeadline  DateTime?          @map("blackhole_deadline")
  rank               Rank?              // Snapshot at activation

  // Relations
  project            Project            @relation(fields: [projectId], references: [id], onDelete: Restrict)
  leader             User               @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  members            TeamMember[]
  weeklyReports      WeeklyReport[]
  evaluationSlots    EvaluationSlot[]
  evaluations        Evaluation[]
  materialRequests   MaterialRequest[]
  damageReports      DamageReport[]
  fabricationRequests FabricationRequest[]
  checkouts          Checkout[]
  conflictFlags      ConflictFlag[]
  feedbackReceived   EvaluationFeedback[] @relation("FeedbackTeamReceiver")

  @@map("teams")
  @@index([projectId])
  @@index([leaderId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String   @map("team_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")
  isLeader  Boolean  @default(false) @map("is_leader")

  // Relations
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
  @@index([teamId])
  @@index([userId])
}

model EvaluationSlot {
  id               String               @id @default(cuid())
  createdAt        DateTime             @default(now()) @map("created_at")
  teamId           String               @map("team_id")
  openedAt         DateTime             @default(now()) @map("opened_at")
  availableWindows Json                 @map("available_windows") // Array of time ranges
  status           EvaluationSlotStatus @default(OPEN)

  // Relations
  team             Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade)
  evaluations      Evaluation[]

  @@map("evaluation_slots")
  @@index([teamId])
}

model Evaluation {
  id                       String           @id @default(cuid())
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime         @updatedAt @map("updated_at")
  slotId                   String           @map("slot_id")
  evaluatorId              String           @map("evaluator_id")
  teamId                   String           @map("team_id")
  projectId                String           @map("project_id")
  status                   EvaluationStatus @default(PENDING)
  tier1Score               Float?           @map("tier1_score")
  tier2Score               Float?           @map("tier2_score")
  tier3Score               Float?           @map("tier3_score")
  overallResult            EvaluationResult? @map("overall_result")
  isStaffEval              Boolean          @default(false) @map("is_staff_eval")
  notificationSentAt       DateTime?        @map("notification_sent_at")
  notificationDelaySeconds Int?             @map("notification_delay_seconds")
  claimedAt                DateTime?        @map("claimed_at")
  completedAt              DateTime?        @map("completed_at")

  // Relations
  slot                     EvaluationSlot   @relation(fields: [slotId], references: [id], onDelete: Restrict)
  evaluator                User             @relation("Evaluator", fields: [evaluatorId], references: [id], onDelete: Restrict)
  team                     Team             @relation(fields: [teamId], references: [id], onDelete: Restrict)
  project                  Project          @relation(fields: [projectId], references: [id], onDelete: Restrict)
  feedback                 EvaluationFeedback[]

  @@map("evaluations")
  @@index([slotId])
  @@index([evaluatorId])
  @@index([teamId])
  @@index([projectId])
}

model EvaluationFeedback {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now()) @map("created_at")
  evaluationId  String       @map("evaluation_id")
  fromRole      FeedbackRole @map("from_role")
  toEvaluatorId String?      @map("to_evaluator_id")
  toTeamId      String?      @map("to_team_id")
  rating        Int          // 1-5
  comment       String?      @db.Text
  isAnonymous   Boolean      @default(true) @map("is_anonymous")

  // Relations
  evaluation    Evaluation   @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  toEvaluator   User?        @relation("FeedbackReceiver", fields: [toEvaluatorId], references: [id], onDelete: SetNull)
  toTeam        Team?        @relation("FeedbackTeamReceiver", fields: [toTeamId], references: [id], onDelete: SetNull)

  @@map("evaluation_feedbacks")
  @@index([evaluationId])
  @@index([toEvaluatorId])
  @@index([toTeamId])
}

model WeeklyReport {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  teamId            String   @map("team_id")
  submittedById     String   @map("submitted_by_id")
  weekNumber        Int      @map("week_number")
  summary           String   @db.Text
  contributionNotes Json     @map("contribution_notes") // Map of userId to contribution string
  photoUrls         String[] @map("photo_urls")
  readmeUpdated     Boolean  @default(false) @map("readme_updated")
  blockersNotes     String?  @db.Text @map("blockers_notes")
  pdfUrl            String?  @map("pdf_url")

  // Relations
  team              Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submittedBy       User     @relation(fields: [submittedById], references: [id], onDelete: Restrict)

  @@unique([teamId, weekNumber]) // Ensure only one report per team per week
  @@map("weekly_reports")
  @@index([teamId])
  @@index([submittedById])
}

model Checkout {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  userId           String         @map("user_id")
  teamId           String?        @map("team_id")
  itemName         String         @map("item_name")
  quantity         Int            @default(1)
  checkedOutAt     DateTime       @default(now()) @map("checked_out_at")
  expectedReturnAt DateTime       @map("expected_return_at")
  returnedAt       DateTime?      @map("returned_at")
  status           CheckoutStatus @default(OUT)

  // Relations
  user             User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  team             Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@map("checkouts")
  @@index([userId])
  @@index([teamId])
}

model FabricationRequest {
  id                     String      @id @default(cuid())
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  userId                 String      @map("user_id")
  teamId                 String?     @map("team_id")
  machineType            MachineType @map("machine_type")
  modelFileUrl           String      @map("model_file_url")
  estimatedMinutes       Int         @map("estimated_minutes")
  estimatedMaterialGrams Float       @map("estimated_material_grams")
  purpose                String      @db.Text
  status                 ReqStatus   @default(PENDING)
  scheduledAt            DateTime?   @map("scheduled_at")
  moderatorNote          String?     @db.Text @map("moderator_note")
  reviewedById           String?     @map("reviewed_by_id")

  // Relations
  user                   User        @relation("Requestor", fields: [userId], references: [id], onDelete: Restrict)
  team                   Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  reviewedBy             User?       @relation("FabricationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("fabrication_requests")
  @@index([userId])
  @@index([teamId])
  @@index([reviewedById])
}

model DamageReport {
  id                 String       @id @default(cuid())
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  reportedById       String       @map("reported_by_id")
  teamId             String?      @map("team_id")
  itemName           String       @map("item_name")
  estimatedValue     Float        @map("estimated_value")
  description        String       @db.Text
  status             DamageStatus @default(REPORTED)
  requiresModeration Boolean      @default(false) @map("requires_moderation")
  moderatorNote      String?      @db.Text @map("moderator_note")
  resolvedById       String?      @map("resolved_by_id")

  // Relations
  reportedBy         User         @relation("Reporter", fields: [reportedById], references: [id], onDelete: Restrict)
  team               Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  resolvedBy         User?        @relation("DamageResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@map("damage_reports")
  @@index([reportedById])
  @@index([teamId])
  @@index([resolvedById])
}

model MaterialRequest {
  id             String            @id @default(cuid())
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  teamId         String            @map("team_id")
  requestedById  String            @map("requested_by_id")
  itemName       String            @map("item_name")
  quantity       Int               @default(1)
  estimatedCost  Float             @map("estimated_cost")
  justification  String            @db.Text
  status         MaterialReqStatus @default(PENDING)
  moderatorNote  String?           @db.Text @map("moderator_note")
  reviewedById   String?           @map("reviewed_by_id")

  // Relations
  team           Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requestedBy    User              @relation("MaterialRequestor", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy     User?             @relation("MaterialReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("material_requests")
  @@index([teamId])
  @@index([requestedById])
  @@index([reviewedById])
}

model ProjectProposal {
  id                   String         @id @default(cuid())
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  proposedById         String         @map("proposed_by_id")
  title                String
  description          String         @db.Text
  proposedRank         Rank           @map("proposed_rank")
  requiredMaterials    String         @db.Text @map("required_materials")
  estimatedCost        Float          @map("estimated_cost")
  learningObjectives   String         @db.Text @map("learning_objectives")
  buildPlan            String         @db.Text @map("build_plan")
  differentiationNotes String?        @db.Text @map("differentiation_notes")
  status               ProposalStatus @default(PENDING)
  moderatorNote        String?        @db.Text @map("moderator_note")
  reviewedById         String?        @map("reviewed_by_id")
  convertedProjectId   String?        @map("converted_project_id")

  // Relations
  proposedBy           User           @relation("ProposalCreator", fields: [proposedById], references: [id], onDelete: Restrict)
  reviewedBy           User?          @relation("ProposalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  convertedProject     Project?       @relation("ConvertedProject", fields: [convertedProjectId], references: [id], onDelete: SetNull)

  @@map("project_proposals")
  @@index([proposedById])
  @@index([reviewedById])
  @@index([convertedProjectId])
}

model Achievement {
  id          String            @id @default(cuid())
  key         String            @unique // e.g., "FIRST_EVAL_GIVEN"
  title       String
  description String            @db.Text
  icon        String

  // Relations
  users       UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(cuid())
  unlockedAt    DateTime    @default(now()) @map("unlocked_at")
  userId        String      @map("user_id")
  achievementId String      @map("achievement_id")

  // Relations
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
  @@index([userId])
  @@index([achievementId])
}

model Notification {
  id         String           @id @default(cuid())
  createdAt  DateTime         @default(now()) @map("created_at")
  userId     String           @map("user_id")
  type       NotificationType
  title      String
  body       String           @db.Text
  isPush     Boolean          @default(false) @map("is_push")
  readAt     DateTime?        @map("read_at")
  actionUrl  String?          @map("action_url")
  deliverAt  DateTime         @default(now()) @map("deliver_at") // For delayed delivery mechanism

  // Relations
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
}

model ConflictFlag {
  id            String         @id @default(cuid())
  createdAt     DateTime       @default(now()) @map("created_at")
  raisedById    String         @map("raised_by_id")
  teamId        String         @map("team_id")
  description   String         @db.Text
  status        ConflictStatus @default(OPEN)
  moderatorNote String?        @db.Text @map("moderator_note")
  reviewedById  String?        @map("reviewed_by_id")

  // Relations
  raisedBy      User           @relation("ConflictRaiser", fields: [raisedById], references: [id], onDelete: Restrict)
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  reviewedBy    User?          @relation("ConflictReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("conflict_flags")
  @@index([raisedById])
  @@index([teamId])
  @@index([reviewedById])
}

model Workshop {
  id           String         @id @default(cuid())
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  title        String
  description  String         @db.Text
  hostId       String         @map("host_id")
  scheduledAt  DateTime       @map("scheduled_at")
  location     String
  rsvpDeadline DateTime?      @map("rsvp_deadline")

  // Relations
  host         User           @relation("WorkshopHost", fields: [hostId], references: [id], onDelete: Restrict)
  rsvps        WorkshopRSVP[]

  @@map("workshops")
  @@index([hostId])
}

model WorkshopRSVP {
  id         String     @id @default(cuid())
  createdAt  DateTime   @default(now()) @map("created_at")
  workshopId String     @map("workshop_id")
  userId     String     @map("user_id")
  status     RsvpStatus @default(GOING)

  // Relations
  workshop   Workshop   @relation(fields: [workshopId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workshopId, userId])
  @@map("workshop_rsvps")
  @@index([workshopId])
  @@index([userId])
}

model LabAccessLog {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now()) @map("created_at")
  userId    String     @map("user_id")
  method    AuthMethod
  success   Boolean
  flagged   Boolean    @default(false)
  note      String?    @db.Text

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("lab_access_logs")
  @@index([userId])
}

model AlumniEvaluator {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  optedInAt  DateTime @default(now()) @map("opted_in_at")
  isActive   Boolean  @default(true) @map("is_active")

  // Relations
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("alumni_evaluators")
  @@index([userId])
}
